# ─────────────────────────────────────────────
#  Campus Nexus — Environment Variables
#  Copy this file to .env and fill in the values
#  Never commit .env to Git
# ─────────────────────────────────────────────

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Get this from: Atlas Dashboard → Your Cluster → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxxx.mongodb.net/campus-nexus?retryWrites=true&w=majority

# Session secret — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret_at_least_64_chars

# JWT secret — generate separately from SESSION_SECRET
JWT_SECRET=replace_with_another_long_random_secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
