<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Nexus | <%= currentPage.charAt(0).toUpperCase() + currentPage.slice(1) %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --sidebar-w: 256px;
            --bg:        #f5f4fb;
            --surface:   #ffffff;
            --border:    #ebebf0;
            --accent:    #7c6af5;
            --accent-dk: #5e4edb;
            --accent-lt: #ede9ff;
            --text:      #1a1a2e;
            --muted:     #8585a0;
            --success:   #10b981;
            --danger:    #ef4444;
            --warning:   #f59e0b;
            --radius:    12px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
        }

        /* ── Sidebar ─────────────────────────────────── */
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 200;
            overflow-y: auto;
        }

        .sidebar-logo {
            padding: 24px 24px 20px;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.05rem;
            color: var(--accent);
            letter-spacing: .02em;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-section {
            padding: 20px 16px 8px;
            font-size: .7rem;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .1em;
        }

        .nav-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 16px;
            margin: 1px 8px;
            border-radius: 8px;
            color: var(--muted);
            font-size: .9rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .15s, color .15s;
        }
        .nav-link i { font-size: 1.05rem; flex-shrink: 0; }
        .nav-link:hover { background: var(--accent-lt); color: var(--accent); }
        .nav-link.active { background: var(--accent-lt); color: var(--accent); font-weight: 700; }
        .nav-link.active i { color: var(--accent); }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px 8px;
            border-top: 1px solid var(--border);
        }

        /* ── Main content ────────────────────────────── */
        .main-content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }

        /* ── Top bar ─────────────────────────────────── */
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 14px 28px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }

        .search-wrap {
            position: relative;
            width: min(340px, 45%);
        }
        .search-wrap i {
            position: absolute;
            left: 12px; top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
            font-size: .95rem;
        }
        .search-input {
            width: 100%;
            padding: 9px 14px 9px 36px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            font-size: .9rem;
            color: var(--text);
            outline: none;
            transition: border-color .2s;
        }
        .search-input:focus { border-color: var(--accent); }

        .topbar-right { display: flex; align-items: center; gap: 20px; }

        .icon-btn {
            background: none; border: none;
            color: var(--muted);
            font-size: 1.15rem;
            cursor: pointer;
            padding: 6px;
            border-radius: 6px;
            transition: color .2s, background .2s;
        }
        .icon-btn:hover { color: var(--accent); background: var(--accent-lt); }

        .avatar-btn {
            display: flex; align-items: center; gap: 10px;
            background: none; border: none;
            cursor: pointer;
            padding: 5px 10px 5px 5px;
            border-radius: 50px;
            border: 1px solid var(--border);
            transition: border-color .2s, background .2s;
        }
        .avatar-btn:hover { border-color: var(--accent); background: var(--accent-lt); }

        .avatar-img {
            width: 32px; height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .avatar-name {
            font-size: .88rem;
            font-weight: 600;
            color: var(--text);
            max-width: 120px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* ── Page body ───────────────────────────────── */
        .page-body { padding: 28px; flex: 1; }

        /* ── Page header ─────────────────────────────── */
        .page-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 24px;
        }
        .page-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            margin: 0;
        }
        .page-subtitle { color: var(--muted); font-size: .88rem; margin: 2px 0 0; }

        /* ── Cards ───────────────────────────────────── */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            display: flex; align-items: center; gap: 16px;
        }

        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        .stat-icon.yellow { background: #fef9c3; color: var(--warning); }
        .stat-icon.green  { background: #dcfce7; color: var(--success); }
        .stat-icon.red    { background: #fee2e2; color: var(--danger);  }

        .stat-value { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.6rem; line-height: 1; }
        .stat-label { font-size: .82rem; color: var(--muted); margin-top: 3px; font-weight: 500; }

        /* ── Table ───────────────────────────────────── */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
        }
        .table-card-header {
            padding: 18px 22px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .table-card-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1rem;
        }

        .table { margin: 0; }
        .table th {
            font-size: .75rem;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            padding: 12px 22px;
            border-bottom: 1px solid var(--border);
            background: #fafafa;
        }
        .table td {
            padding: 13px 22px;
            vertical-align: middle;
            border-bottom: 1px solid var(--border);
            font-size: .9rem;
        }
        .table tbody tr:last-child td { border-bottom: none; }
        .table tbody tr:hover { background: var(--bg); }

        .student-id-badge {
            font-size: .78rem;
            color: var(--muted);
            background: var(--bg);
            padding: 2px 8px;
            border-radius: 4px;
            font-family: 'DM Mono', monospace;
        }

        /* ── Attendance radio buttons ────────────────── */
        .att-radio-group { display: flex; gap: 4px; justify-content: center; }
        .att-label {
            display: flex; align-items: center; justify-content: center;
            width: 28px; height: 28px;
            border-radius: 6px;
            cursor: pointer;
            border: 1.5px solid var(--border);
            transition: background .15s, border-color .15s;
        }
        .att-label:has(input:checked) { border-color: transparent; }
        .att-label.p:has(input:checked) { background: #dcfce7; }
        .att-label.a:has(input:checked) { background: #fee2e2; }
        .att-label.l:has(input:checked) { background: #fef9c3; }
        .att-label input { display: none; }
        .att-label i { font-size: .85rem; }
        .att-label.p i { color: var(--success); }
        .att-label.a i { color: var(--danger);  }
        .att-label.l i { color: var(--warning); }

        /* ── Buttons ─────────────────────────────────── */
        .btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: .88rem;
            font-weight: 500;
            border: none; cursor: pointer;
            transition: opacity .2s, transform .1s;
            text-decoration: none;
        }
        .btn:hover { opacity: .88; transform: translateY(-1px); }
        .btn-accent  { background: var(--accent);  color: #fff; }
        .btn-ghost   { background: var(--bg);       color: var(--text); border: 1px solid var(--border); }
        .btn-danger  { background: #fee2e2;          color: var(--danger); }
        .btn-sm      { padding: 5px 10px; font-size: .82rem; }

        /* ── Badge ───────────────────────────────────── */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: .75rem;
            font-weight: 600;
        }
        .badge-success { background: #dcfce7; color: #16a34a; }
        .badge-warning { background: #fef9c3; color: #b45309; }
        .badge-info    { background: var(--accent-lt); color: var(--accent); }

        /* ── Academic cards ──────────────────────────── */
        .subject-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            display: flex; align-items: stretch;
            overflow: hidden;
        }
        .subject-icon {
            width: 56px; flex-shrink: 0;
            background: var(--accent);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; color: #fff;
        }
        .subject-body { padding: 14px 16px; }
        .subject-code { font-size: .75rem; font-weight: 700; color: var(--accent); letter-spacing: .06em; text-transform: uppercase; }
        .subject-name { font-weight: 600; font-size: .95rem; margin: 2px 0; }
        .subject-teacher { font-size: .82rem; color: var(--muted); }

        /* ── Profile & Settings ──────────────────────── */
        .profile-cover {
            height: 90px;
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dk) 100%);
            border-radius: var(--radius) var(--radius) 0 0;
            margin: -1px -1px 0;
        }
        .profile-avatar-wrap {
            margin-top: -44px;
            padding: 0 24px;
        }
        .profile-avatar {
            width: 88px; height: 88px;
            border-radius: 50%;
            border: 4px solid var(--surface);
            box-shadow: 0 2px 12px rgba(0,0,0,.12);
        }

        .info-row {
            display: grid; grid-template-columns: 1fr 1fr; gap: 0 32px;
            padding: 20px 24px 0;
        }
        .info-field { margin-bottom: 20px; }
        .info-label { font-size: .75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 4px; }
        .info-value { font-size: .95rem; font-weight: 500; padding-bottom: 8px; border-bottom: 1px solid var(--border); }

        .setting-row {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
        }
        .setting-row:last-child { border-bottom: none; }
        .setting-label { font-weight: 600; font-size: .9rem; }
        .setting-hint  { font-size: .82rem; color: var(--muted); }

        /* Bootstrap switch override */
        .form-check-input:checked { background-color: var(--accent); border-color: var(--accent); }

        /* ── Calendar widget ─────────────────────────── */
        .cal-widget {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px;
        }
        .cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .cal-month  { font-family: 'Syne', sans-serif; font-weight: 700; font-size: .9rem; }
        .cal-nav    { background: none; border: none; color: var(--muted); cursor: pointer; font-size: .9rem; padding: 2px 5px; border-radius: 4px; transition: color .15s; }
        .cal-nav:hover { color: var(--accent); }
        .cal-grid   { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
        .cal-day-hd { font-size: .68rem; font-weight: 700; color: var(--muted); text-align: center; padding: 4px 0; }
        .cal-day    { font-size: .78rem; text-align: center; padding: 5px 2px; border-radius: 6px; cursor: pointer; transition: background .15s; }
        .cal-day:hover { background: var(--accent-lt); }
        .cal-today  { background: var(--accent) !important; color: #fff !important; font-weight: 700; }

        /* ── Fees ────────────────────────────────────── */
        .fees-total {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dk) 100%);
            color: #fff;
            border-radius: var(--radius);
            padding: 24px;
            margin-bottom: 20px;
        }
        .fees-total-label { font-size: .82rem; opacity: .75; margin-bottom: 4px; }
        .fees-total-value { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; }

        /* ── Dropdown ────────────────────────────────── */
        .dropdown-menu {
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
            padding: 8px;
        }
        .dropdown-item {
            border-radius: 6px;
            padding: 8px 12px;
            font-size: .88rem;
            display: flex; align-items: center; gap: 10px;
            color: var(--text);
            transition: background .15s;
        }
        .dropdown-item:hover { background: var(--accent-lt); color: var(--accent); }
        .dropdown-item.text-danger:hover { background: #fee2e2; color: var(--danger); }
        .dropdown-divider { border-color: var(--border); margin: 6px 0; }

        /* ── Modal ───────────────────────────────────── */
        .modal-content  { border: 1px solid var(--border); border-radius: var(--radius); }
        .modal-header   { border-bottom: 1px solid var(--border); padding: 18px 22px; }
        .modal-footer   { border-top: 1px solid var(--border); padding: 14px 22px; }
        .modal-title    { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; }
        .form-label     { font-size: .8rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
        .form-control   { border-color: var(--border); border-radius: 8px; font-family: 'DM Sans', sans-serif; }
        .form-control:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(124,106,245,.1); }

        /* ── Responsive ──────────────────────────────── */
        @media (max-width: 900px) {
            .sidebar { transform: translateX(-100%); transition: transform .25s; }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .stat-grid { grid-template-columns: 1fr 1fr; }
        }
        @media (max-width: 560px) {
            .stat-grid { grid-template-columns: 1fr; }
            .page-body { padding: 16px; }
        }
    </style>
</head>
<body>

<!-- ── Sidebar ──────────────────────────────────────────── -->
<nav class="sidebar" id="sidebar">
    <div class="sidebar-logo">⬡ Campus Nexus</div>

    <div class="sidebar-section">Main</div>
    <a class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" href="/dashboard">
        <i class="bi bi-grid-1x2"></i> Dashboard
    </a>
    <a class="nav-link <%= currentPage === 'admission' ? 'active' : '' %>" href="/admission">
        <i class="bi bi-person-plus"></i> Admission
    </a>
    <a class="nav-link <%= currentPage === 'students' ? 'active' : '' %>" href="/students">
        <i class="bi bi-people"></i> Students
    </a>

    <div class="sidebar-section">Academics</div>
    <a class="nav-link <%= currentPage === 'academic' ? 'active' : '' %>" href="/academic">
        <i class="bi bi-book"></i> Academic
    </a>
    <a class="nav-link <%= currentPage === 'fees' ? 'active' : '' %>" href="/fees">
        <i class="bi bi-wallet2"></i> Fees
    </a>

    <div class="sidebar-section">Account</div>
    <a class="nav-link <%= currentPage === 'profile' ? 'active' : '' %>" href="/profile">
        <i class="bi bi-person-circle"></i> My Profile
    </a>
    <a class="nav-link <%= currentPage === 'settings' ? 'active' : '' %>" href="/settings">
        <i class="bi bi-gear"></i> Settings
    </a>

    <div class="sidebar-footer">
        <a class="nav-link" href="/logout" style="color: var(--danger);">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>
</nav>

<!-- ── Main content ──────────────────────────────────────── -->
<div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="mainSearch" class="search-input" placeholder="Search...">
        </div>

        <div class="topbar-right">
            <button class="icon-btn" aria-label="Notifications">
                <i class="bi bi-bell"></i>
            </button>

            <div class="dropdown">
                <button class="avatar-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
                    <img
                        src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=7c6af5&color=fff&size=64"
                        alt="<%= user.name %>"
                        class="avatar-img"
                    >
                    <span class="avatar-name"><%= user.name %></span>
                    <i class="bi bi-chevron-down" style="font-size:.7rem;color:var(--muted);margin-right:4px;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/profile"><i class="bi bi-person"></i> My Profile</a></li>
                    <li><a class="dropdown-item" href="/settings"><i class="bi bi-gear"></i> Settings</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- Page body -->
    <div class="page-body">

        <%# ═══════════════════════════════════════════════════ %>
        <%# DASHBOARD / STUDENTS                                %>
        <%# ═══════════════════════════════════════════════════ %>
        <% if (currentPage === 'dashboard' || currentPage === 'students') { %>

            <div class="page-header">
                <div>
                    <h1 class="page-title">
                        <%= currentPage === 'students' ? 'Students' : 'Dashboard' %>
                    </h1>
                    <p class="page-subtitle">
                        <%= new Date().toLocaleDateString('en-PH', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
                    </p>
                </div>
                <button class="btn btn-accent" onclick="openCreateModal()">
                    <i class="bi bi-plus-lg"></i> Add Student
                </button>
            </div>

            <div class="stat-grid">
                <div class="stat-card">
                    <div class="stat-icon yellow"><i class="bi bi-mortarboard"></i></div>
                    <div>
                        <div class="stat-value" id="statTotal"><%= stats.totalStudents %></div>
                        <div class="stat-label">Total Students</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-check2-square"></i></div>
                    <div>
                        <div class="stat-value" id="statPresent"><%= stats.present %></div>
                        <div class="stat-label">Present Today</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon red"><i class="bi bi-x-square"></i></div>
                    <div>
                        <div class="stat-value" id="statAbsent"><%= stats.absent %></div>
                        <div class="stat-label">Absent Today</div>
                    </div>
                </div>
            </div>

            <div class="table-card">
                <div class="table-card-header">
                    <span class="table-card-title">Attendance &amp; Records</span>
                    <span class="badge badge-info"><%= students.length %> students</span>
                </div>
                <% if (students.length === 0) { %>
                    <p style="padding:32px;text-align:center;color:var(--muted);">No students found.</p>
                <% } else { %>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Student ID</th>
                                <th>Full Name</th>
                                <th class="text-center">Present</th>
                                <th class="text-center">Absent</th>
                                <th class="text-center">Leave</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="searchContent">
                            <% students.forEach(s => { %>
                            <tr class="searchable-item">
                                <td><span class="student-id-badge"><%= s.studentId %></span></td>
                                <td style="font-weight:600;"><%= s.fullname %></td>
                                <td class="text-center">
                                    <label class="att-label p">
                                        <input type="radio" name="att_<%= s.studentId %>" value="present" checked class="att-radio">
                                        <i class="bi bi-check-lg"></i>
                                    </label>
                                </td>
                                <td class="text-center">
                                    <label class="att-label a">
                                        <input type="radio" name="att_<%= s.studentId %>" value="absent" class="att-radio">
                                        <i class="bi bi-x-lg"></i>
                                    </label>
                                </td>
                                <td class="text-center">
                                    <label class="att-label l">
                                        <input type="radio" name="att_<%= s.studentId %>" value="leave" class="att-radio">
                                        <i class="bi bi-clock"></i>
                                    </label>
                                </td>
                                <td>
                                    <div style="display:flex;gap:6px;">
                                        <button
                                            class="btn btn-ghost btn-sm"
                                            onclick="openEditModal(this)"
                                            data-id="<%= s.studentId %>"
                                            data-name="<%= s.fullname %>"
                                        ><i class="bi bi-pencil"></i></button>
                                        <button
                                            class="btn btn-danger btn-sm"
                                            onclick="deleteEntry(this)"
                                            data-id="<%= s.studentId %>"
                                        ><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } %>
            </div>

        <%# ═══════════════════════════════════════════════════ %>
        <%# ADMISSION                                           %>
        <%# ═══════════════════════════════════════════════════ %>
        <% } else if (currentPage === 'admission') { %>

            <div class="page-header">
                <div>
                    <h1 class="page-title">Admission</h1>
                    <p class="page-subtitle">Register a new student</p>
                </div>
            </div>

            <div class="card" style="max-width:640px;padding:28px;">
                <h6 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:20px;">Student Admission Form</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control" placeholder="Juan">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input type="text" class="form-control" placeholder="dela Cruz">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Student ID</label>
                        <input type="text" class="form-control" placeholder="2024-0001">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="student@school.edu.ph">
                    </div>
                    <div class="col-12 mt-2">
                        <button class="btn btn-accent">Submit Registration</button>
                    </div>
                </div>
            </div>

        <%# ═══════════════════════════════════════════════════ %>
        <%# ACADEMIC                                            %>
        <%# ═══════════════════════════════════════════════════ %>
        <% } else if (currentPage === 'academic') { %>

            <div class="page-header">
                <div>
                    <h1 class="page-title">Academic</h1>
                    <p class="page-subtitle">Current subjects &amp; schedule</p>
                </div>
            </div>

            <div class="row g-3" id="searchContent">
                <% (typeof subjects !== 'undefined' ? subjects : []).forEach(sub => { %>
                <div class="col-md-6 col-lg-4 searchable-item">
                    <div class="subject-card">
                        <div class="subject-icon"><i class="bi bi-journal-text"></i></div>
                        <div class="subject-body">
                            <div class="subject-code"><%= sub.code %></div>
                            <div class="subject-name"><%= sub.name %></div>
                            <div class="subject-teacher"><i class="bi bi-person-fill me-1"></i><%= sub.teacher %></div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

        <%# ═══════════════════════════════════════════════════ %>
        <%# FEES                                                %>
        <%# ═══════════════════════════════════════════════════ %>
        <% } else if (currentPage === 'fees') { %>

            <div class="page-header">
                <div>
                    <h1 class="page-title">Fees</h1>
                    <p class="page-subtitle">Fee collections &amp; payment status</p>
                </div>
            </div>

            <% const feeList = (typeof fees !== 'undefined' ? fees : []); %>
            <div class="fees-total" style="max-width:480px;">
                <div class="fees-total-label">Total Fees Due</div>
                <div class="fees-total-value">
                    ₱<%= feeList.filter(f=>f.status!=='Paid').reduce((s,f)=>s + parseFloat(String(f.amount).replace(/,/g,'')),0).toLocaleString() %>
                </div>
            </div>

            <div class="table-card" style="max-width:640px;">
                <div class="table-card-header">
                    <span class="table-card-title">Fee Breakdown</span>
                </div>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="searchContent">
                            <% feeList.forEach(f => { %>
                            <tr class="searchable-item">
                                <td style="font-weight:600;"><%= f.type %></td>
                                <td style="font-weight:600;">₱<%= f.amount %></td>
                                <td>
                                    <span class="badge <%= f.status === 'Paid' ? 'badge-success' : 'badge-warning' %>">
                                        <%= f.status %>
                                    </span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

        <%# ═══════════════════════════════════════════════════ %>
        <%# PROFILE                                             %>
        <%# ═══════════════════════════════════════════════════ %>
        <% } else if (currentPage === 'profile') { %>

            <div class="page-header">
                <h1 class="page-title">My Profile</h1>
            </div>

            <div class="card" style="max-width:600px;">
                <div class="profile-cover"></div>
                <div class="profile-avatar-wrap">
                    <img
                        src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=7c6af5&color=fff&size=128"
                        alt="Avatar"
                        class="profile-avatar"
                    >
                </div>
                <div style="padding:8px 24px 4px;">
                    <h5 style="font-family:'Syne',sans-serif;font-weight:700;margin:0;"><%= user.name %></h5>
                    <span class="badge badge-info" style="margin-top:6px;"><%= user.role || 'Student' %></span>
                </div>
                <div class="info-row">
                    <div class="info-field">
                        <div class="info-label">Student ID</div>
                        <div class="info-value"><%= user.studentId %></div>
                    </div>
                    <div class="info-field">
                        <div class="info-label">Email</div>
                        <div class="info-value"><%= user.email || '—' %></div>
                    </div>
                    <div class="info-field">
                        <div class="info-label">Full Name</div>
                        <div class="info-value"><%= user.name %></div>
                    </div>
                    <div class="info-field">
                        <div class="info-label">Role</div>
                        <div class="info-value"><%= user.role || 'Student' %></div>
                    </div>
                </div>
                <div style="padding:0 24px 24px;">
                    <button class="btn btn-accent btn-sm">Edit Profile</button>
                </div>
            </div>

        <%# ═══════════════════════════════════════════════════ %>
        <%# SETTINGS                                            %>
        <%# ═══════════════════════════════════════════════════ %>
        <% } else if (currentPage === 'settings') { %>

            <div class="page-header">
                <h1 class="page-title">Settings</h1>
            </div>

            <div class="card" style="max-width:560px;">
                <div class="setting-row">
                    <div>
                        <div class="setting-label">Dark Mode</div>
                        <div class="setting-hint">Switch the interface theme</div>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" role="switch" id="darkModeToggle">
                    </div>
                </div>
                <div class="setting-row">
                    <div>
                        <div class="setting-label">Email Notifications</div>
                        <div class="setting-hint">Receive updates about attendance</div>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" role="switch" checked>
                    </div>
                </div>
                <div class="setting-row">
                    <div>
                        <div class="setting-label">Sign Out All Devices</div>
                        <div class="setting-hint">Revoke all active sessions</div>
                    </div>
                    <a href="/logout" class="btn btn-danger btn-sm">Sign Out</a>
                </div>
            </div>

        <% } %>

    </div><!-- /page-body -->
</div><!-- /main-content -->

<!-- ── CRUD Modal ──────────────────────────────────────── -->
<div class="modal fade" id="crudModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Manage Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:20px 22px;">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" id="recordName" class="form-control" placeholder="Juan dela Cruz" maxlength="100">
                </div>
                <div class="mb-3">
                    <label class="form-label">Student ID</label>
                    <input type="text" id="recordDisplayId" class="form-control" placeholder="2024-0001" maxlength="20">
                </div>
                <input type="hidden" id="recordId">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-accent" onclick="saveRecord()">Save</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ── Calendar ──────────────────────────────────────────
    let calDate = new Date();

    function renderCalendar() {
        const grid = document.getElementById('calendarGrid');
        const label = document.getElementById('calMonthLabel');
        if (!grid) return;

        grid.innerHTML = '';
        ['S','M','T','W','T','F','S'].forEach(d => {
            const el = document.createElement('div');
            el.className = 'cal-day-hd';
            el.textContent = d;
            grid.appendChild(el);
        });

        const year = calDate.getFullYear();
        const month = calDate.getMonth();
        if (label) label.textContent = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(calDate);

        const firstDay = new Date(year, month, 1).getDay();
        const lastDay  = new Date(year, month + 1, 0).getDate();
        const today    = new Date();

        for (let x = 0; x < firstDay; x++) {
            grid.appendChild(document.createElement('div'));
        }
        for (let i = 1; i <= lastDay; i++) {
            const el = document.createElement('div');
            el.className = 'cal-day';
            el.textContent = i;
            const isToday = i === today.getDate() && month === today.getMonth() && year === today.getFullYear();
            if (isToday) el.classList.add('cal-today');
            grid.appendChild(el);
        }
    }

    document.getElementById('prevMonth')?.addEventListener('click', () => {
        calDate.setMonth(calDate.getMonth() - 1); renderCalendar();
    });
    document.getElementById('nextMonth')?.addEventListener('click', () => {
        calDate.setMonth(calDate.getMonth() + 1); renderCalendar();
    });

    // ── Attendance live stats ─────────────────────────────
    function updateStats() {
        const groups = {};
        document.querySelectorAll('.att-radio').forEach(r => {
            if (!groups[r.name]) groups[r.name] = null;
            if (r.checked) groups[r.name] = r.value;
        });
        let present = 0, absent = 0;
        Object.values(groups).forEach(v => {
            if (v === 'present') present++;
            if (v === 'absent')  absent++;
        });
        const pEl = document.getElementById('statPresent');
        const aEl = document.getElementById('statAbsent');
        if (pEl) pEl.textContent = present;
        if (aEl) aEl.textContent = absent;
    }

    document.addEventListener('change', e => {
        if (e.target.classList.contains('att-radio')) updateStats();
    });

    // ── Search filter ─────────────────────────────────────
    document.getElementById('mainSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.searchable-item').forEach(el => {
            el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    // ── CRUD Modal ────────────────────────────────────────
    const crudModal = new bootstrap.Modal(document.getElementById('crudModal'));

    function openCreateModal() {
        document.getElementById('modalTitle').textContent = 'Add New Student';
        document.getElementById('recordId').value = '';
        document.getElementById('recordName').value = '';
        document.getElementById('recordDisplayId').value = '';
        crudModal.show();
    }

    function openEditModal(btn) {
        document.getElementById('modalTitle').textContent = 'Edit Student Record';
        // Read from data attributes — avoids JS injection
        document.getElementById('recordId').value        = btn.dataset.id;
        document.getElementById('recordName').value      = btn.dataset.name;
        document.getElementById('recordDisplayId').value = btn.dataset.id;
        crudModal.show();
    }

    async function saveRecord() {
        const id   = document.getElementById('recordId').value.trim();
        const name = document.getElementById('recordName').value.trim();
        const sid  = document.getElementById('recordDisplayId').value.trim();

        if (!name || !sid) { alert('Name and Student ID are required.'); return; }

        const endpoint = id ? `/api/students/update/${encodeURIComponent(id)}` : '/api/students/create';
        const method   = id ? 'PUT' : 'POST';

        try {
            const res = await fetch(endpoint, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fullname: name, studentId: sid })
            });
            if (res.ok) {
                crudModal.hide();
                location.reload();
            } else {
                const body = await res.json().catch(() => ({}));
                alert(body.error || 'Failed to save. Check the API route.');
            }
        } catch {
            alert('Network error. Please try again.');
        }
    }

    async function deleteEntry(btn) {
        const id = btn.dataset.id;
        if (!confirm(`Delete student ${id}?`)) return;
        try {
            const res = await fetch(`/api/students/delete/${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (res.ok) location.reload();
            else alert('Delete failed.');
        } catch {
            alert('Network error.');
        }
    }

    // ── Init ──────────────────────────────────────────────
    renderCalendar();
    updateStats();
</script>
</body>
</html>
