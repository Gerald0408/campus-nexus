<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Nexus | Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:       #0c0c0e;
            --surface:  #141418;
            --border:   #232328;
            --accent:   #7c6af5;
            --accent2:  #a394ff;
            --text:     #f2f2f5;
            --muted:    #7a7a8a;
            --danger:   #f05a5a;
            --success:  #4ade80;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100dvh;
            display: flex;
            overflow: hidden;
        }

        /* ── Splash ── */
        #splash {
            position: fixed; inset: 0;
            background: var(--bg);
            display: flex; align-items: center; justify-content: center;
            z-index: 100;
            transition: opacity .5s ease, visibility .5s;
        }
        #splash.hidden { opacity: 0; visibility: hidden; }

        .splash-mark {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 2.4rem;
            background: linear-gradient(135deg, #fff 30%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: pulse 1.6s ease-in-out infinite;
        }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }

        /* ── Layout ── */
        .auth-grid {
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            width: 100%;
            opacity: 0;
            transition: opacity .7s ease .2s;
        }
        .auth-grid.visible { opacity: 1; }

        /* Left panel */
        .auth-form-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 40px;
            background: var(--bg);
        }

        .auth-form-inner { width: 100%; max-width: 360px; }

        .auth-logo {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: .05em;
            color: var(--accent2);
            margin-bottom: 48px;
        }

        .auth-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 2.2rem;
            line-height: 1.1;
            margin-bottom: 8px;
        }

        .auth-subtitle { color: var(--muted); font-size: .92rem; margin-bottom: 36px; }

        /* Alert banners */
        .alert {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: .875rem;
            margin-bottom: 24px;
        }
        .alert-error   { background: rgba(240,90,90,.1);  border: 1px solid rgba(240,90,90,.25);  color: #f78b8b; }
        .alert-success { background: rgba(74,222,128,.1); border: 1px solid rgba(74,222,128,.25); color: #6fdf9e; }

        /* Form fields */
        .field { margin-bottom: 22px; }
        .field label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 8px;
        }

        .input-wrap {
            position: relative;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            transition: border-color .2s;
        }
        .input-wrap:focus-within { border-color: var(--accent); }

        .input-wrap input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            padding: 10px 0;
        }
        .input-wrap input::placeholder { color: #3e3e4a; }

        .toggle-pw {
            background: none; border: none;
            color: var(--muted);
            cursor: pointer;
            padding: 0;
            line-height: 1;
            font-size: 1rem;
            transition: color .2s;
        }
        .toggle-pw:hover { color: var(--accent2); }

        .forgot {
            display: block;
            text-align: right;
            font-size: .82rem;
            color: var(--muted);
            text-decoration: none;
            margin-top: -12px;
            margin-bottom: 28px;
            transition: color .2s;
        }
        .forgot:hover { color: var(--accent2); }

        .btn-primary {
            width: 100%;
            padding: 13px;
            background: var(--accent);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: .9rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background .2s, transform .15s;
        }
        .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
        .btn-primary:active { transform: translateY(0); }

        .auth-footer {
            margin-top: 36px;
            font-size: .87rem;
            color: var(--muted);
        }
        .auth-footer a {
            color: var(--accent2);
            text-decoration: none;
            font-weight: 500;
            margin-left: 6px;
        }
        .auth-footer a:hover { text-decoration: underline; }

        /* Right panel */
        .auth-hero {
            background: linear-gradient(145deg, #1a1730 0%, #0f0f18 60%, #1a1730 100%);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            padding: 60px;
        }

        /* Decorative orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: .35;
        }
        .orb-1 { width: 360px; height: 360px; background: #7c6af5; top: -80px; right: -80px; }
        .orb-2 { width: 280px; height: 280px; background: #2e2166; bottom: 60px; left: -60px; }

        .hero-content { position: relative; z-index: 2; color: #fff; }

        .hero-eyebrow {
            font-family: 'Syne', sans-serif;
            font-size: .78rem;
            font-weight: 600;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--accent2);
            margin-bottom: 20px;
        }

        .hero-title {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 3.4rem;
            line-height: 1.05;
            margin-bottom: 20px;
        }

        .hero-body {
            font-size: 1rem;
            color: rgba(255,255,255,.55);
            max-width: 320px;
            line-height: 1.7;
        }

        /* Feature pills */
        .pill-list { margin-top: 40px; display: flex; flex-direction: column; gap: 12px; }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 50px;
            padding: 8px 16px;
            font-size: .85rem;
            width: fit-content;
        }
        .pill i { color: var(--accent2); }

        @media (max-width: 900px) {
            .auth-hero { display: none; }
            .auth-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<div id="splash">
    <div class="splash-mark">Campus Nexus</div>
</div>

<div class="auth-grid" id="auth-grid">

    <!-- Form panel -->
    <div class="auth-form-panel">
        <div class="auth-form-inner">
            <div class="auth-logo">⬡ Campus Nexus</div>
            <h1 class="auth-title">Welcome<br>back.</h1>
            <p class="auth-subtitle">Sign in to your student portal</p>

            <% if (error) { %>
                <div class="alert alert-error" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span><%= error %></span>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span><%= success %></span>
                </div>
            <% } %>

            <form action="/api/auth/login" method="POST" autocomplete="off" novalidate>
                <div class="field">
                    <label for="studentId">Student ID</label>
                    <div class="input-wrap">
                        <input
                            type="text"
                            id="studentId"
                            name="studentId"
                            placeholder="e.g. 2024-0001"
                            required
                            autocomplete="username"
                            maxlength="20">
                    </div>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <div class="input-wrap">
                        <input
                            type="password"
                            id="password"
                            name="password"
                            placeholder="••••••••"
                            required
                            autocomplete="current-password">
                        <button type="button" class="toggle-pw" id="togglePw" aria-label="Toggle password visibility">
                            <i class="bi bi-eye-slash" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <a href="#" class="forgot">Forgot password?</a>

                <button type="submit" class="btn-primary">Sign In</button>
            </form>

            <p class="auth-footer">
                No account yet?
                <a href="/register">Create one</a>
            </p>
        </div>
    </div>

    <!-- Hero panel -->
    <div class="auth-hero">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="hero-content">
            <p class="hero-eyebrow">Student Information System</p>
            <h2 class="hero-title">Your campus,<br>one portal.</h2>
            <p class="hero-body">Access grades, schedules, fees, and announcements — all in one place, any time.</p>
            <div class="pill-list">
                <div class="pill"><i class="bi bi-mortarboard-fill"></i> Academic records &amp; grades</div>
                <div class="pill"><i class="bi bi-cash-stack"></i> Fee tracking &amp; payments</div>
                <div class="pill"><i class="bi bi-people-fill"></i> Student directory</div>
            </div>
        </div>
    </div>

</div>

<script>
    window.addEventListener('load', () => {
        setTimeout(() => {
            document.getElementById('splash').classList.add('hidden');
            document.getElementById('auth-grid').classList.add('visible');
        }, 1200);
    });

    const togglePw   = document.getElementById('togglePw');
    const pwField    = document.getElementById('password');
    const toggleIcon = document.getElementById('toggleIcon');

    togglePw.addEventListener('click', () => {
        const isPassword = pwField.type === 'password';
        pwField.type = isPassword ? 'text' : 'password';
        toggleIcon.className = isPassword ? 'bi bi-eye' : 'bi bi-eye-slash';
    });
</script>
</body>
</html>
